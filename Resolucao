kwh = float(input("Quantidade de kWh consumida: "))
tipo = input("Tipo de instalação (R para residência, C para comércio, I para indústria): ").upper()

if tipo == "R":
    if kwh <= 500:
        preco_unitario = 0.40
    else:
        preco_unitario = 0.65
elif tipo == "C":
    if kwh <= 1000:
        preco_unitario = 0.55
    else:
        preco_unitario = 0.60
elif tipo == "I":
    if kwh <= 5000:
        preco_unitario = 0.55
    else:
        preco_unitario = 0.60
else:
    preco_unitario = -1
    print("Tipo de instalação inválido!")

if preco_unitario != -1:
    total = kwh * preco_unitario
    print(f"Preço por kWh: R$ {preco_unitario:.2f}")
    print(f"Total a pagar pelo fornecimento de energia: R$ {total:.2f}")
